# Application environment
APP_ENV=production
FLASK_DEBUG=0
AUTO_CREATE_DB=0

# Required secret: leave blank in this committed template
SECRET_KEY=

# Production database
DATABASE_URL=sqlite:////opt/secure_student_forum/instance/forum.db


APP_BASE_URL=https://3.142.152.134/

# Reverse-proxy handling
# Enable only when the application is behind the trusted local Nginx proxy.
USE_PROXY_FIX=1

# Session security
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax
SESSION_HOURS=2
SINGLE_SESSION_PER_USER=1

# Authentication controls
LOGIN_FAILURE_LIMIT=5
LOGIN_LOCK_MINUTES=15

# Email verification and token lifetime
EMAIL_VERIFICATION_REQUIRED=1
EMAIL_TOKEN_MINUTES=60
PASSWORD_RESET_MINUTES=30
DEV_SHOW_TOKENS=0

# SMTP configuration
# Set MAIL_ENABLED=1 only after valid SMTP settings are configured.
MAIL_ENABLED=0
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USE_SSL=0
MAIL_USERNAME=secure2516Group6@gmail.com
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=secure2516Group6@gmail.com

# Rate limiting
RATELIMIT_ENABLED=1
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_DEFAULT=200 per day;50 per hour

# Application logging
LOG_FILE=/opt/secure_student_forum/logs/app.log